@echo off
title Vizora — Unpack
color 0A
echo.
echo  Vizora — Unpack and Setup
echo  ==========================
echo.
echo  This script is just a helper to remind you what to do
echo  after downloading and unzipping Vizora from Google Drive.
echo.
echo  Steps to get started:
echo.
echo  [1] Make sure Python is installed
echo      Download from: https://python.org
echo      During install: check "Add Python to PATH"
echo      Recommended path: D:\Python
echo.
echo  [2] Make sure Node.js is installed
echo      Download from: https://nodejs.org
echo      Choose the LTS version
echo      Recommended path: D:\nodejs
echo.
echo  [3] Make sure Ollama is installed
echo      Download from: https://ollama.com
echo.
echo  [4] Run setup.bat in the phase-12-installer folder
echo      It will install everything and launch Vizora automatically.
echo.
echo  That's it! Vizora runs 100%% locally.
echo  No cloud. No accounts. Your data never leaves your machine.
echo.
pause